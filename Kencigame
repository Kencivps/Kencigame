<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kenciblack Game Ultra Sound</title>
    <style>
        :root { --glass: rgba(255, 255, 255, 0.2); }
        body { margin: 0; overflow: hidden; font-family: 'Arial Black', sans-serif; background: #000; }
        
        #hud { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; color: white; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; padding: 15px; pointer-events: auto; }
        .stat { background: var(--glass); backdrop-filter: blur(10px); padding: 10px; border-radius: 12px; border: 1px solid white; min-width: 90px; text-align: center; }
        
        .title-area { text-align: center; }
        .title-area h1 { margin: 0; font-size: 18px; letter-spacing: 2px; }
        .title-area span { font-size: 10px; color: #4f46e5; display: block; }

        #shop { position: fixed; top: 50%; right: 10px; transform: translateY(-50%); display: flex; flex-direction: column; gap: 10px; pointer-events: auto; }
        .item-btn { width: 70px; height: 75px; background: var(--glass); border: 2px solid #fff; border-radius: 15px; color: white; cursor: pointer; font-size: 10px; backdrop-filter: blur(5px); }
        .active-power { border-color: #00ff00; box-shadow: 0 0 15px #00ff00; }

        .screen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 100; color: white; pointer-events: auto; }
        .btn-play { padding: 15px 40px; font-size: 20px; background: #4f46e5; border: none; border-radius: 50px; color: white; cursor: pointer; margin-top: 20px; }

        .controls { position: fixed; bottom: 30px; width: 100%; display: flex; justify-content: space-around; pointer-events: auto; }
        .move-btn { width: 85px; height: 75px; background: var(--glass); border: 2px solid #fff; border-radius: 20px; font-size: 30px; color: white; }
    </style>
</head>
<body>

<div id="overlay" class="screen">
    <h1 id="main-text">KENCIBLACK GAME</h1>
    <p id="sub-text">¿Estás listo para el siguiente mundo?</p>
    <button class="btn-play" id="start-trigger">JUGAR AHORA</button>
</div>

<div id="hud">
    <div class="top-bar">
        <div class="stat">⏱️ <span id="timer">00:45</span></div>
        <div class="title-area">
            <h1>KENCIBLACK GAME</h1>
            <span id="lvl-display">NIVEL 1</span>
        </div>
        <div class="stat" style="color: #ffd700;">💰 <span id="coins">0</span></div>
    </div>

    <div id="shop">
        <button class="item-btn" id="btn-skate" onclick="buy('skate')">🛹<br>300<br>PATINETA</button>
        <button class="item-btn" id="btn-fly" onclick="buy('fly')">🚀<br>800<br>VOLADOR</button>
        <button class="stat" style="margin-top:10px; cursor:pointer;" id="pause-trigger">PAUSA</button>
    </div>

    <div class="controls">
        <button class="move-btn" id="lBtn">←</button>
        <button class="move-btn" id="rBtn">→</button>
    </div>
</div>

<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js';

// --- SISTEMA DE AUDIO ---
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

function playSound(freq, type, duration, vol = 0.1) {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = type;
    osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
    gain.gain.setValueAtTime(vol, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.start();
    osc.stop(audioCtx.currentTime + duration);
}

const sfx = {
    coin: () => { playSound(880, 'sine', 0.2); setTimeout(() => playSound(1320, 'sine', 0.2), 50); },
    explosion: () => { playSound(100, 'sawtooth', 0.8, 0.3); playSound(50, 'square', 0.5, 0.2); },
    levelUp: () => { [440, 554, 659, 880].forEach((f, i) => setTimeout(() => playSound(f, 'square', 0.4), i * 150)); },
    start: () => { playSound(523, 'triangle', 0.5); setTimeout(() => playSound(1046, 'triangle', 0.5), 200); }
};

// --- LÓGICA DEL JUEGO ---
let isPaused = true;
let coins = 0, timeLeft = 45, level = 1;
let objects = [], columns = [];
let targetX = 0, powerupActive = false;
const worlds = [0x4338ca, 0x059669, 0xd97706, 0x7c3aed, 0xdb2777];

const scene = new THREE.Scene();
scene.background = new THREE.Color(worlds[0]);
scene.fog = new THREE.Fog(worlds[0], 5, 45);

const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
camera.position.set(0, 4, 8);

const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
document.body.appendChild(renderer.domElement);

scene.add(new THREE.AmbientLight(0xffffff, 0.7));
const sun = new THREE.DirectionalLight(0xffffff, 1);
sun.position.set(5, 10, 5);
scene.add(sun);

const player = new THREE.Mesh(new THREE.BoxGeometry(1.2, 1.2, 1.2), new THREE.MeshStandardMaterial({ color: 0xffffff }));
player.position.y = 0.6;
scene.add(player);

const ground = new THREE.Mesh(new THREE.PlaneGeometry(20, 500), new THREE.MeshStandardMaterial({ color: 0x111111 }));
ground.rotation.x = -Math.PI / 2;
scene.add(ground);

function spawnColumn() {
    if(isPaused) return;
    const geo = new THREE.BoxGeometry(1, 15, 1);
    const mat = new THREE.MeshStandardMaterial({ color: worlds[level % worlds.length] });
    const cL = new THREE.Mesh(geo, mat); const cR = new THREE.Mesh(geo, mat);
    cL.position.set(-10, 7.5, -50); cR.position.set(10, 7.5, -50);
    scene.add(cL, cR); columns.push(cL, cR);
}

function spawnEnv() {
    if(isPaused) return;
    const isCoin = Math.random() > 0.4;
    const geo = isCoin ? new THREE.SphereGeometry(0.4) : new THREE.BoxGeometry(1.5, 1.5, 1.5);
    const mat = new THREE.MeshStandardMaterial({ color: isCoin ? 0xffd700 : 0x333333 });
    const obj = new THREE.Mesh(geo, mat);
    const yPos = (powerupActive && Math.random() > 0.5) ? 4 : 0.7;
    obj.position.set((Math.random()-0.5)*12, yPos, -40);
    obj.userData = { type: isCoin ? 'coin' : 'obs' };
    scene.add(obj); objects.push(obj);
}

setInterval(spawnEnv, 800);
setInterval(spawnColumn, 1200);

// --- ACCIONES ---
document.getElementById('start-trigger').onclick = () => {
    if (audioCtx.state === 'suspended') audioCtx.resume();
    sfx.start();
    isPaused = false;
    document.getElementById('overlay').style.display = 'none';
};

document.getElementById('pause-trigger').onclick = () => {
    isPaused = !isPaused;
    document.getElementById('overlay').style.display = isPaused ? 'flex' : 'none';
    document.getElementById('main-text').innerText = "PAUSA";
    sfx.start();
};

window.buy = (type) => {
    if(type === 'skate' && coins >= 300 && !powerupActive) {
        coins -= 300; startPowerup('skate');
        sfx.levelUp();
    } else if(type === 'fly' && coins >= 800 && !powerupActive) {
        coins -= 800; startPowerup('fly');
        sfx.levelUp();
    }
    document.getElementById('coins').innerText = coins;
};

function startPowerup(type) {
    powerupActive = true;
    const btn = document.getElementById(type === 'skate' ? 'btn-skate' : 'btn-fly');
    btn.classList.add('active-power');
    if(type === 'fly') player.position.y = 4;
    if(type === 'skate') player.scale.set(1.5, 0.5, 1.5);
    setTimeout(() => {
        powerupActive = false;
        player.position.y = 0.6; player.scale.set(1, 1, 1);
        btn.classList.remove('active-power');
    }, 30000);
}

document.getElementById('lBtn').ontouchstart = () => targetX -= 2.5;
document.getElementById('rBtn').ontouchstart = () => targetX += 2.5;

setInterval(() => {
    if(!isPaused) {
        timeLeft--;
        if(timeLeft <= 0) {
            timeLeft = 45; level++;
            sfx.levelUp();
            document.getElementById('lvl-display').innerText = `NIVEL ${level}`;
            const c = worlds[level % worlds.length];
            scene.background.set(c); scene.fog.color.set(c);
        }
        document.getElementById('timer').innerText = `00:${String(timeLeft).padStart(2, '0')}`;
    }
}, 1000);

function animate() {
    requestAnimationFrame(animate);
    if(!isPaused) {
        targetX = Math.max(-6, Math.min(6, targetX));
        player.position.x += (targetX - player.position.x) * 0.1;
        columns.forEach((c, i) => {
            c.position.z += 0.5;
            if(c.position.z > 10) { scene.remove(c); columns.splice(i, 1); }
        });
        objects.forEach((obj, i) => {
            obj.position.z += 0.4 + (level * 0.05);
            if(player.position.distanceTo(obj.position) < 1.3) {
                if(obj.userData.type === 'coin') {
                    sfx.coin();
                    coins += 50;
                    document.getElementById('coins').innerText = coins;
                    scene.remove(obj); objects.splice(i, 1);
                } else if(!powerupActive || obj.position.y > 1) {
                    sfx.explosion();
                    isPaused = true;
                    document.getElementById('overlay').style.display = 'flex';
                    document.getElementById('main-text').innerText = "CHOCÓ JUNTO CON...";
                    setTimeout(() => location.reload(), 2000);
                }
            }
        });
    }
    renderer.render(scene, camera);
}
animate();
</script>
</body>
</html>
